# Public
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DISABLE_SIGNUP=false
# Database
MONGODB_URI=
MASTER_DB_NAME=master
TENANT_DB_PREFIX=org_
DEFAULT_ORGANIZATION_SLUG=club
# Authentication
JWT_SECRET=your-secret-key
# SMTP Vault
SMTP_VAULT_SECRET=32-characters-only
SMTP_VAULT_ENCRYPTION_ALGORITHM=aes-256-gcm
# Gmail SMTP
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
# Upstash
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Upstash QStash
QSTASH_URL="https://qstash-us-east-1.upstash.io"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
# Backblaze B2 (S3-Compatible)
# Note: Use an S3-compatible app key (not the master key).
B2_S3_REGION=us-east-005
B2_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_BUCKET=
B2_BUCKET_ID=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=